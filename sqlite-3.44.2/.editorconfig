root = true

# Глобальные настройки
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Специальные настройки для Makefile и скриптов сборки
[Makefile*]
indent_style = tab

[*.{sh,bash}]
indent_style = space
indent_size = 4